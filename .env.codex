# Ready-to-use Codex CLI profile. Run `codex login`, then copy to .env.
# No API URL or API key is needed. Works from localhost and the LAN by default.
AI_PROVIDER=codex-cli
HOST=0.0.0.0
PORT=3888
CODEX_CLI_PATH=codex

# Leave empty to let Codex choose the default for PenEcho's isolated CLI
# session, or enter a model ID accepted by the installed Codex CLI. PenEcho
# does not load model from ~/.codex/config.toml.
CODEX_CLI_MODEL=
# Known values: low | medium | high | xhigh | max; other strings are allowed.
# Empty lets Codex choose the effort default for the isolated session.
AI_EFFORT=
CODEX_CLI_TIMEOUT_SECONDS=120
